# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# Alpaca (use paper trading keys to start!)
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets   # Switch to https://api.alpaca.markets for live

# Alpaca Crypto (same keys, different endpoint)
ALPACA_CRYPTO_BASE_URL=https://data.alpaca.markets

# Telegram alerts (optional but recommended)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Risk controls
MAX_POSITION_PCT=0.10         # Max 10% of portfolio per position
DAILY_LOSS_LIMIT_PCT=0.03     # Kill switch at 3% daily loss
MAX_TRADE_USD=500             # Hard cap per single order
PAPER_MODE=true               # Set false only when you're ready for live
