# === LLM ===
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6   # execution layer only; or claude-opus-4-7 / claude-haiku-4-5-20251001

# === Broker (shared by both layers) ===
ALPACA_API_KEY=
ALPACA_API_SECRET=            # canonical (legacy ALPACA_SECRET_KEY still read as fallback)
ALPACA_PAPER=true
TRADING_MODE=paper            # paper | live
# Going live requires BOTH: TRADING_MODE=live AND ALPACA_PAPER=false.
# Deprecated (still honored): PAPER_MODE=false forces live; ALPACA_BASE_URL overrides the endpoint.

# === Market data (research layer) ===
FMP_API_KEY=
FINNHUB_API_KEY=

# === Telegram ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Risk controls (execution layer) ===
MAX_POSITION_PCT=0.10         # max fraction of portfolio per position
DAILY_LOSS_LIMIT_PCT=0.03     # daily-loss kill-switch
TRAILING_STOP_PCT=0.08        # per-position trailing stop from high

# === Logging ===
LOG_LEVEL=info                # trace | debug | info | warn | error
